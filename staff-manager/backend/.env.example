# ============================================================
# GLOWTIME — Staff & Manager Backend Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ไขค่าให้ตรงกับระบบของคุณ
# ============================================================

# Server
PORT=5001
NODE_ENV=development

# JWT (ใช้ค่าเดียวกับ Customer Backend — shared JWT_SECRET)
JWT_SECRET=glowtime_super_secret_key_change_me_in_production
JWT_EXPIRES_IN=7d

# ============================================================
# เมื่อเชื่อมต่อ MySQL จริง (ปัจจุบันยังใช้ Mock JSON Data)
# ============================================================
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASS=your_password
# DB_NAME=glowtime_db
